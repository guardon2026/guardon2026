# ─────────────────────────────────────────
# Database (Phase 1)
# Local dev uses local PostgreSQL (Docker NOT available).
# Create DB: psql -d postgres -c "CREATE DATABASE guardon;"
# Enable PostGIS: psql -d guardon -c "CREATE EXTENSION IF NOT EXISTS postgis;"
# ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/guardon?schema=public

# ─────────────────────────────────────────
# NextAuth v5 (Phase 2)
# Generate secret: openssl rand -base64 32
# ─────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ─────────────────────────────────────────
# Kakao OAuth (Phase 2) — developers.kakao.com
# ─────────────────────────────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ─────────────────────────────────────────
# Kakao 알림톡 (Phase 9) — 비즈니스 채널 심사 2~4주 소요
# ─────────────────────────────────────────
KAKAO_ALIMTALK_SENDER_KEY=
KAKAO_ALIMTALK_PLUS_FRIEND_ID=

# ─────────────────────────────────────────
# SMS 폴백 (Phase 9) — SOLAPI / 쿨SMS
# ─────────────────────────────────────────
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=

# ─────────────────────────────────────────
# 파일 스토리지 (Phase 5) — 자격증 이미지
# AWS S3 or local encrypted storage path
# ─────────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=guardon-credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────
# Credential file encryption (Phase 5) — AES-256
# Generate: openssl rand -hex 32
# ─────────────────────────────────────────
ENCRYPTION_KEY=

# ─────────────────────────────────────────
# Public app config
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GuardOn
