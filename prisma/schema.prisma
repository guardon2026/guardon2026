generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  COMPANY_OWNER  // 업체 대표 (FR1, RBAC)
  WORKER         // 인력·구직자 (FR2, RBAC)
  ADMIN          // 플랫폼 관리자 (FR7, RBAC)
}

enum CompanyStatus {
  PENDING   // 심사 중 (FR7)
  APPROVED  // 승인 완료
  REJECTED  // 반려
}

enum AvailabilityStatus {
  AVAILABLE    // 가용 (FR6)
  UNAVAILABLE  // 불가
  BUSY         // 배치 중
}

enum CredentialType {
  SECURITY_INSTRUCTOR  // 경비지도사
  BODYGUARD            // 신변보호사
  SECURITY_TRAINING    // 신임교육이수증
  SPECIAL_SECURITY     // 특수경비이수증
  CIVIL_POLICE         // 청원경찰
  KRAV_MAGA            // 크라브마가
  CPR                  // CPR
}

enum CredentialStatus {
  PENDING   // 심사 중 (FR8)
  APPROVED  // 인증 완료 (FR9, FR10)
  REJECTED  // 반려 (FR9)
}

enum WorkField {
  GENERAL_SECURITY      // 일반경비
  BODYGUARD_SERVICE     // 신변보호
  SPECIAL_SECURITY      // 특수경비
  KRAV_MAGA_INSTRUCTOR  // 크라브마가강사
  EVENT_SECURITY        // 행사경비
}

enum SosStatus {
  DISPATCHING  // 알림 발송 중 (FR18)
  PENDING      // 수락 대기 (FR23)
  CONFIRMED    // 확정 (FR22)
  UNRESOLVED   // 미해결 (FR24)
  CANCELLED    // 취소
  COMPLETED    // 완료
}

enum SosMatchStatus {
  NOTIFIED   // 알림 발송됨
  ACCEPTED   // 인력 수락 (FR20)
  REJECTED   // 인력 거절 (FR20)
  CONFIRMED  // 업체 최종 확정 (FR21)
}

enum SosUrgency {
  NORMAL    // 일반
  FAST      // 빠른 모집
  URGENT    // 긴급
  CRITICAL  // 즉시
}

enum SosVisibility {
  APPROVED_USERS  // 승인 업체와 프로필 완료 인력
  COMPANIES_ONLY  // 승인 업체만
  PRIVATE_LINK    // 링크 공유 대상
}

enum SosApplicationStatus {
  NEW
  REVIEWING
  CONTACTED
  SELECTED
  REJECTED
  CANCELLED
  REPORTED
}

enum SosApplicantType {
  COMPANY
  GUARD
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum NotificationChannel {
  KAKAO_ALIMTALK  // 카카오 알림톡 (FR25)
  SMS             // SMS 폴백 (FR26)
  IN_APP          // 인앱 알림 (FR27)
}

enum NotificationStatus {
  SENT       // 발송됨
  FAILED     // 발송 실패
  DELIVERED  // 수신됨
  READ       // 읽음
}

// ─────────────────────────────────────────
// USER (공통 계정)
// ─────────────────────────────────────────

// NOTE: A partial index on deletedAt WHERE deletedAt IS NULL exists in
// prisma/migrations/0002_postgis_indexes/migration.sql. Prisma cannot
// express partial indexes in schema syntax. Do NOT remove it from
// migrations — it is critical for PIPA soft-delete query performance.
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?   @unique
  kakaoId       String?   @unique  // 카카오 소셜 로그인 (FR3)
  name          String?
  role          UserRole?
  // PIPA soft-delete (RESEARCH.md Pitfall 7, T-01-02-02)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  company       Company?       @relation("CompanyOwner")
  workerProfile WorkerProfile?
  notifications Notification[]
  accounts      Account[]
  sessions      Session[]
  consentLogs   ConsentLog[]
  pointAccount  PointAccount?
  sosApplications SosApplication[] @relation("SosApplicantUser")
  contactViewLogs ContactViewLog[] @relation("ContactViewer")
  ownedContactViewLogs ContactViewLog[] @relation("ContactOwner")
  reportsMade    Report[] @relation("ReportsMade")
  auditLogs       AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────
// NEXTAUTH ADAPTER TABLES
// ─────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────
// COMPANY (경비업체 — 테넌트 단위)
// ─────────────────────────────────────────

model Company {
  id              String        @id @default(cuid())
  ownerId         String        @unique  // FR4, 업체 대표
  name            String
  licenseNumber   String        @unique  // 경비업 허가번호 (FR1, FR40)
  businessRegistrationNumber String?      // 사업자등록번호
  businessRegistrationFileUrl String?      // 사업자등록증 파일 URL
  securityLicenseFileUrl String?           // 경비업 허가·경호 가능 증빙 파일 URL
  additionalProofFileUrls Json?            // 추가 증빙 서류 URL 목록
  licenseVerified Boolean       @default(false)  // 관리자 승인 여부 (FR7)
  description     String?
  address         String
  city            String                          // 검색 필터용 (FR12)
  district        String                          // 시/구 단위
  phone           String
  kakaoOpenChatUrl String?                         // 카카오 오픈채팅 링크 (경비 인력 문의용)
  status          CompanyStatus @default(PENDING)
  isActive        Boolean       @default(false)   // 관리자 승인 후 활성화
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  owner       User         @relation("CompanyOwner", fields: [ownerId], references: [id])
  sosRequests SosRequest[]
  sosApplications SosApplication[]
  companyDocuments CompanyDocument[]
  subscriptions Subscription[]
  ratings     Rating[]     @relation("CompanyRating")

  @@map("companies")
}

// ─────────────────────────────────────────
// WORKER PROFILE (인력·구직자)
// ─────────────────────────────────────────

model WorkerProfile {
  id               String             @id @default(cuid())
  userId           String             @unique
  workFields            WorkField[]        // 분야 (FR13)
  declaredCredentials   CredentialType[]   @default([]) // 자기신고 자격증 (UI 표시용)
  experienceYears       Int                @default(0)  // 경력 연수 (FR14)
  profileImageUrl       String?            // 프로필 사진
  height                Int?               // 키 (cm)
  weight                Int?               // 몸무게 (kg)
  address          String
  city             String
  district         String
  // Float lat/lng for fallback reads (FR5, FR12)
  latitude         Float?
  longitude        Float?
  // PostGIS geography column for ST_DWithin radius search (INFR-05)
  // NOTE: $queryRaw calls MUST use tagged template literals (T-01-02-01)
  location         Unsupported("geography(Point,4326)")?
  desiredHourlyRate Int?              // 시급 희망 (FR5)
  bio              String?
  availability     AvailabilityStatus @default(UNAVAILABLE)  // FR6
  averageRating    Float              @default(0)
  totalMatches     Int                @default(0)
  isProfilePublic  Boolean            @default(true)
  // 본인 인증
  rrn              String?            // 주민등록번호 (마스킹 저장: 900101-*******)
  rrnVerifiedAt    DateTime?
  // 계좌 인증
  bankName         String?
  bankAccount      String?
  bankHolder       String?
  bankVerifiedAt   DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials Credential[] // FR8~FR11
  projects    GuardProject[]
  sosMatches  SosMatch[]
  sosApplications SosApplication[]
  ratings     Rating[]     @relation("WorkerRatings")

  @@map("worker_profiles")
}

// ─────────────────────────────────────────
// CREDENTIAL (자격증 인증 뱃지)
// ─────────────────────────────────────────

model Credential {
  id              String           @id @default(cuid())
  workerProfileId String
  type            CredentialType
  status          CredentialStatus @default(PENDING)  // FR8, FR9
  documentUrl     String           // 서류 업로드 URL (암호화 스토리지, FR38)
  issuedDate      DateTime?        // 자격증 발급일
  approvedAt      DateTime?        // 관리자 승인 시각 (FR9)
  rejectedAt      DateTime?
  rejectionReason String?
  adminNote       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@unique([workerProfileId, type])  // 동일 자격증 중복 방지
  @@map("credentials")
}

// ─────────────────────────────────────────
// SOS REQUEST (긴급 매칭 요청)
// ─────────────────────────────────────────

model SosRequest {
  id                  String      @id @default(cuid())
  companyId           String                         // 테넌트 격리 (FR39)
  title               String
  locationAddress     String                         // 집결지 주소 (FR22)
  city                String
  district            String
  // Float lat/lng for fallback reads
  latitude            Float?
  longitude           Float?
  // PostGIS geography column for ST_DWithin radius search (INFR-05)
  // NOTE: $queryRaw calls MUST use tagged template literals (T-01-02-01)
  location            Unsupported("geography(Point,4326)")?
  scheduledAt         DateTime                       // 배치 시작 날짜·시간 (FR17)
  scheduledEndAt      DateTime?                      // 배치 종료 날짜·시간 (다일 근무)
  scheduleDays        Json?                          // 날짜별 배치 시간 [{date, startTime, endTime}]
  requiredCount       Int                            // 필요 인원 (FR17)
  requiredFields      WorkField[]                    // 필요 분야 (FR17)
  requiredCredentials CredentialType[]               // 필요 자격증 (FR17)
  hourlyRate          Int                            // 시급 (FR17)
  urgencyLevel        SosUrgency  @default(URGENT)   // 게시판 긴급도
  serviceType         String?                        // 경호·행사·의전 등 표시용
  region              String?                        // 게시판 지역 표기
  addressDetail       String?
  addressVisibility   String       @default("APPLICANTS_ONLY")
  applicationDeadline DateTime?
  budgetTotal         Int?
  budgetPerPerson     Int?
  budgetType          String       @default("DAILY")
  paymentMethod       String?
  requirements        Json?
  visibility          SosVisibility @default(APPROVED_USERS)
  allowCompanyApplicants Boolean   @default(true)
  allowGuardApplicants   Boolean   @default(true)
  ownerContactVisible    Boolean   @default(false)
  isAdConfirmed          Boolean   @default(false)
  viewCount              Int       @default(0)
  applicationCount       Int       @default(0)
  closedAt               DateTime?
  siteManagerContact  String?                        // 현장 담당자 연락처
  dressCode           String?                        // 복장 규정: FORMAL | TACTICAL | CASUAL | OTHER
  dressCodeNote       String?                        // 기타 복장 규정 설명
  description         String?
  receiptInfo         Json?                              // 현금영수증/세금계산서 발행 정보
  status              SosStatus   @default(DISPATCHING)  // FR23
  radiusKm            Float       @default(20)           // 현재 발송 반경 (FR19)
  dispatchedAt        DateTime?                          // 알림 최초 발송 시각
  expandedAt          DateTime?                          // 반경 확장 시각 (FR19)
  confirmedAt         DateTime?                          // 매칭 확정 시각
  unresolvedAt        DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // 테넌트 격리: company에서만 접근 가능
  company       Company        @relation(fields: [companyId], references: [id])
  sosMatches    SosMatch[]
  sosApplications SosApplication[]
  workContracts WorkContract[]
  notifications Notification[]
  contactViewLogs ContactViewLog[]

  @@index([companyId])
  @@index([status])
  @@index([scheduledAt])
  @@index([applicationDeadline])
  @@index([urgencyLevel])
  @@map("sos_requests")
}

// ─────────────────────────────────────────
// SOS MATCH (인력 수락/거절/확정)
// ─────────────────────────────────────────

model SosMatch {
  id              String         @id @default(cuid())
  sosRequestId    String
  workerProfileId String
  status          SosMatchStatus @default(NOTIFIED)
  notifiedAt      DateTime       @default(now())  // FR18
  respondedAt     DateTime?                       // 수락/거절 시각 (FR20)
  confirmedAt        DateTime?                       // 업체 최종 확정 시각 (FR21)
  missionReportedAt  DateTime?                       // 경비 인력 임무 완료 보고 시각
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  sosRequest    SosRequest    @relation(fields: [sosRequestId], references: [id])
  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id])
  rating        Rating?
  workContract  WorkContract?

  @@unique([sosRequestId, workerProfileId])
  @@index([sosRequestId])
  @@index([workerProfileId])
  @@map("sos_matches")
}

// ─────────────────────────────────────────
// RATING (평점)
// ─────────────────────────────────────────

model Rating {
  id              String   @id @default(cuid())
  sosMatchId      String   @unique
  companyId       String                      // 평점 남긴 업체 (FR30)
  workerProfileId String
  score           Int                         // 1~5점 (FR30)
  comment         String?
  createdAt       DateTime @default(now())

  sosMatch      SosMatch      @relation(fields: [sosMatchId], references: [id])
  company       Company       @relation("CompanyRating", fields: [companyId], references: [id])
  workerProfile WorkerProfile @relation("WorkerRatings", fields: [workerProfileId], references: [id])

  @@index([workerProfileId])  // 평점 집계 (FR31)
  @@map("ratings")
}

// ─────────────────────────────────────────
// SOS APPLICATION (업체·개인 경호인 지원서)
// ─────────────────────────────────────────

model SosApplication {
  id              String               @id @default(cuid())
  sosRequestId    String
  applicantUserId String
  applicantType   SosApplicantType
  companyId       String?
  workerProfileId String?
  status          SosApplicationStatus @default(NEW)
  availableHeadcount Int?
  availableStartAt   DateTime?
  availableEndAt     DateTime?
  proposedRate       Int?
  proposedTotal      Int?
  contactName        String?
  contactPhone       String?
  contactEmail       String?
  message            String?
  introFileUrl       String?
  experienceSummary  String?
  profileConsent     Boolean          @default(false)
  adminMemo          String?
  contactedAt        DateTime?
  selectedAt         DateTime?
  rejectedAt         DateTime?
  cancelledAt        DateTime?
  reportedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  sosRequest    SosRequest     @relation(fields: [sosRequestId], references: [id], onDelete: Cascade)
  applicantUser User           @relation("SosApplicantUser", fields: [applicantUserId], references: [id], onDelete: Cascade)
  company       Company?       @relation(fields: [companyId], references: [id])
  workerProfile WorkerProfile? @relation(fields: [workerProfileId], references: [id])
  contactViewLogs ContactViewLog[]

  @@unique([sosRequestId, applicantUserId])
  @@index([sosRequestId])
  @@index([applicantUserId])
  @@index([companyId])
  @@index([workerProfileId])
  @@index([status])
  @@map("sos_applications")
}

model CompanyDocument {
  id          String   @id @default(cuid())
  companyId   String
  type        String   // BUSINESS_REGISTRATION | SECURITY_LICENSE | INSURANCE | OTHER
  fileUrl     String
  fileName    String?
  mimeType    String?
  status      String   @default("SUBMITTED")
  adminMemo   String?
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([type])
  @@map("company_documents")
}

model GuardProject {
  id              String   @id @default(cuid())
  workerProfileId String
  title           String
  role            String?
  startedAt       DateTime?
  endedAt         DateTime?
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@index([workerProfileId])
  @@map("guard_projects")
}

model ContactViewLog {
  id                 String   @id @default(cuid())
  viewerUserId       String
  contactOwnerUserId String?
  sosRequestId       String?
  applicationId      String?
  reason             String?
  viewedAt           DateTime @default(now())

  viewer       User            @relation("ContactViewer", fields: [viewerUserId], references: [id], onDelete: Cascade)
  contactOwner User?           @relation("ContactOwner", fields: [contactOwnerUserId], references: [id])
  sosRequest   SosRequest?     @relation(fields: [sosRequestId], references: [id], onDelete: Cascade)
  application  SosApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([viewerUserId])
  @@index([contactOwnerUserId])
  @@index([sosRequestId])
  @@index([applicationId])
  @@map("contact_view_logs")
}

model Report {
  id             String       @id @default(cuid())
  reporterUserId String
  targetType     String
  targetId       String
  reason         String
  description    String?
  status         ReportStatus @default(OPEN)
  adminMemo      String?
  createdAt      DateTime     @default(now())
  resolvedAt     DateTime?

  reporter User @relation("ReportsMade", fields: [reporterUserId], references: [id], onDelete: Cascade)

  @@index([reporterUserId])
  @@index([targetType, targetId])
  @@index([status])
  @@map("reports")
}

model Subscription {
  id            String           @id @default(cuid())
  companyId     String
  plan          SubscriptionPlan @default(FREE)
  status        String           @default("ACTIVE")
  startedAt     DateTime         @default(now())
  endedAt       DateTime?
  nextBillingAt DateTime?
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@map("subscriptions")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────
// NOTIFICATION (알림 이력)
// ─────────────────────────────────────────

model Notification {
  id             String              @id @default(cuid())
  userId         String
  sosRequestId   String?
  type           String              // NotificationType string for flexibility
  channel        NotificationChannel
  status         NotificationStatus  @default(SENT)
  title          String
  body           String
  isRead         Boolean             @default(false)
  sentAt         DateTime?
  failedAt       DateTime?
  fallbackSentAt DateTime?           // SMS 폴백 발송 시각 (FR26)
  createdAt      DateTime            @default(now())

  user       User        @relation(fields: [userId], references: [id])
  sosRequest SosRequest? @relation(fields: [sosRequestId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────
// POINT ACCOUNT & TRANSACTION (포인트 시스템)
// ─────────────────────────────────────────

model PointAccount {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions PointTransaction[]

  @@map("point_accounts")
}

model PointTransaction {
  id           String   @id @default(cuid())
  accountId    String
  amount       Int      // 양수 = 충전/획득, 음수 = 차감
  type         String   // ADMIN_CHARGE | SOS_DEDUCT | WORKER_DEDUCT | REFUND
  description  String
  sosRequestId   String?
  receiptInfo    Json?
  taxCompleted   Boolean  @default(false)
  createdAt      DateTime @default(now())

  account PointAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("point_transactions")
}

// ─────────────────────────────────────────
// WORK CONTRACT (일용직 근로계약서)
// ─────────────────────────────────────────

model WorkContract {
  id           String @id @default(cuid())
  sosRequestId String
  sosMatchId   String @unique

  // 사업주(업체 대표) 입력 정보
  employerBizNumber String?  // 사업자등록번호
  employerName      String?  // 업체명
  employerCeoName   String?  // 대표자 성명
  employerAddress   String?  // 업체 주소
  employerSignedAt  DateTime?

  // 근로자(경비 인력) 입력 정보
  workerRealName      String?  // 성명
  workerBirthDate     String?  // 생년월일 (YYMMDD)
  workerAddress       String?  // 주소
  workerPhone         String?  // 연락처
  workerBankName      String?  // 은행명
  workerAccountNum    String?  // 계좌번호
  workerAccountHolder String?  // 예금주
  workerSignedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sosRequest SosRequest @relation(fields: [sosRequestId], references: [id])
  sosMatch   SosMatch   @relation(fields: [sosMatchId], references: [id])

  @@index([sosRequestId])
  @@map("work_contracts")
}

// ─────────────────────────────────────────
// CONSENT LOG (개인정보 동의 — FR37, T-01-02-03)
// ─────────────────────────────────────────

model ConsentLog {
  id          String   @id @default(cuid())
  userId      String
  consentType String   // TERMS | PRIVACY | LOCATION
  agreedAt    DateTime @default(now())
  version     String   // 약관 버전 (non-repudiable audit trail)
  ipAddress   String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("consent_logs")
}
